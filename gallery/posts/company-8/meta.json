viewBox=\"0 0 60 44\" style=\"margin-bottom:12px;\"><path d=\"M0 26.4C0 16.8 4.2 9.6 12.6 4.8L16.2 9.6C10.8 13.2 8.4 17.4 9 22.2H16.2C20.4 22.2 23.4 25.2 23.4 29.4V35.4C23.4 39.6 20.4 42.6 16.2 42.6H7.2C3 42.6 0 39.6 0 35.4V26.4ZM33 26.4C33 16.8 37.2 9.6 45.6 4.8L49.2 9.6C43.8 13.2 41.4 17.4 42 22.2H49.2C53.4 22.2 56.4 25.2 56.4 29.4V35.4C56.4 39.6 53.4 42.6 49.2 42.6H40.2C36 42.6 33 39.6 33 35.4V26.4Z\" fill=\"rgba(255,140,0,0.2)\"/></svg>\n    <div style=\"font-size:36px; font-weight:700; color:#fff; line-height:1.35; letter-spacing:-0.5px;\">The day is not far when India will be the hub of industrial manufacturing and the world will be looking towards it.</div>\n    <div style=\"display:flex; align-items:center; gap:12px; margin-top:24px;\">\n      <div style=\"width:3px; height:36px; background:#ff8c00;\"></div>\n      <div>\n        <div style=\"font-size:18px; font-weight:700; color:#ff8c00;\">Narendra Modi</div>\n        <div style=\"font-size:14px; font-weight:300; color:rgba(255,255,255,0.4);\">Prime Minister of India</div>\n      </div>\n    </div>\n  </div>\n\n  <!-- Divider -->\n  <div style=\"position:absolute; top:530px; left:48px; right:48px; display:flex; align-items:center; gap:16px;\">\n    <div style=\"flex:1; height:1px; background:rgba(255,255,255,0.06);\"></div>\n    <div style=\"font-size:16px; font-weight:300; color:rgba(255,140,0,0.5); letter-spacing:4px; text-transform:uppercase;\">The Numbers</div>\n    <div style=\"flex:1; height:1px; background:rgba(255,255,255,0.06);\"></div>\n  </div>\n\n  <!-- 4 Stat Cards: 2x2 grid -->\n  <div style=\"position:absolute; top:580px; left:48px; right:48px; display:flex; flex-wrap:wrap; gap:16px;\">\n\n    <!-- 99% -->\n    <div style=\"width:476px; border:1px solid rgba(0,102,68,0.25); padding:32px; text-align:center;\">\n      <div style=\"font-size:80px; font-weight:900; color:#006644; line-height:1; letter-spacing:-4px;\">99%</div>\n      <div style=\"font-size:16px; font-weight:300; color:rgba(255,255,255,0.5); margin-top:10px; letter-spacing:2px; text-transform:uppercase;\">Phones Made Domestically</div>\n    </div>\n\n    <!-- 85% -->\n    <div style=\"width:476px; border:1px solid rgba(255,140,0,0.25); padding:32px; text-align:center;\">\n      <div style=\"font-size:80px; font-weight:900; color:#ff8c00; line-height:1; letter-spacing:-4px;\">85%</div>\n      <div style=\"font-size:16px; font-weight:300; color:rgba(255,255,255,0.5); margin-top:10px; letter-spacing:2px; text-transform:uppercase;\">Drop in Mobile Imports</div>\n    </div>\n\n    <!-- 200% -->\n    <div style=\"width:476px; border:1px solid rgba(255,140,0,0.25); padding:32px; text-align:center;\">\n      <div style=\"font-size:80px; font-weight:900; color:#ff8c00; line-height:1; letter-spacing:-4px;\">200%</div>\n      <div style=\"font-size:16px; font-weight:300; color:rgba(255,255,255,0.5); margin-top:10px; letter-spacing:2px; text-transform:uppercase;\">Manufacturing Job Growth</div>\n    </div>\n\n    <!-- $300B -->\n    <div style=\"width:476px; border:1px solid rgba(0,102,68,0.25); padding:32px; text-align:center;\">\n      <div style=\"font-size:80px; font-weight:900; color:#006644; line-height:1; letter-spacing:-4px;\">$300B</div>\n      <div style=\"font-size:16px; font-weight:300; color:rgba(255,255,255,0.5); margin-top:10px; letter-spacing:2px; text-transform:uppercase;\">Electronics Target by 2026</div>\n    </div>\n\n  </div>\n\n  <!-- Timeline bar -->\n  <div style=\"position:absolute; bottom:110px; left:48px; right:48px; display:flex; align-items:center;\">\n    <div style=\"text-align:center; width:100px;\">\n      <div style=\"font-size:14px; font-weight:700; color:rgba(255,255,255,0.4);\">2014</div>\n      <div style=\"font-size:11px; font-weight:300; color:rgba(255,255,255,0.25);\">Make in India<br>launched</div>\n    </div>\n    <div style=\"flex:1; height:2px; background:linear-gradient(90deg, rgba(255,140,0,0.3), rgba(0,102,68,0.5));\"></div>\n    <div style=\"text-align:center; width:100px;\">\n      <div style=\"font-size:14px; font-weight:700; color:rgba(255,255,255,0.4);\">2020</div>\n      <div style=\"font-size:11px; font-weight:300; color:rgba(255,255,255,0.25);\">Atmanirbhar<br>Bharat</div>\n    </div>\n    <div style=\"flex:1; height:2px; background:linear-gradient(90deg, rgba(0,102,68,0.5), #006644);\"></div>\n    <div style=\"text-align:center; width:100px;\">\n      <div style=\"font-size:14px; font-weight:700; color:#006644;\">2026</div>\n      <div style=\"font-size:11px; font-weight:300; color:rgba(255,255,255,0.25);\">$300B Target</div>\n    </div>\n  </div>\n\n  <!-- Footer -->\n  <div style=\"position:absolute; bottom:28px; left:48px; right:48px; display:flex; justify-content:space-between; align-items:center;\">\n    <div style=\"font-size:12px; color:rgba(255,255,255,0.25);\">cucircuits.com</div>\n    <div style=\"font-size:12px; color:rgba(255,255,255,0.2);\">Source: PIB India, IBEF, Business Standard</div>\n  </div>\n\n</div>"
