v>\n\n  <!-- Center stats -->\n  <div style=\"position:absolute; top:710px; left:380px; width:310px;\">\n    <div style=\"background:rgba(232,160,76,0.1); border:1px solid rgba(232,160,76,0.2); border-radius:16px; padding:24px; margin-bottom:16px; text-align:center;\">\n      <div style=\"font-size:52px; font-weight:900; color:#E8A04C;\">26.3%</div>\n      <div style=\"font-size:15px; color:rgba(255,255,255,0.6); margin-top:4px;\">CAGR through 2030 (GVR)</div>\n    </div>\n    <div style=\"background:rgba(184,115,51,0.1); border:1px solid rgba(184,115,51,0.2); border-radius:16px; padding:24px; text-align:center;\">\n      <div style=\"font-size:36px;\">&#9992;&#65039;</div>\n      <div style=\"font-size:20px; font-weight:700; color:#B87333; margin-top:4px;\">Aerospace</div>\n      <div style=\"font-size:13px; color:rgba(255,255,255,0.5); margin-top:4px;\">Lightweight parts for defense &amp; space programs</div>\n    </div>\n  </div>\n\n  <!-- Right stats -->\n  <div style=\"position:absolute; top:710px; left:720px; width:310px;\">\n    <div style=\"background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:16px; padding:24px; margin-bottom:16px; text-align:center;\">\n      <div style=\"font-size:52px; font-weight:900; color:#FFFFFF;\">$699M</div>\n      <div style=\"font-size:15px; color:rgba(255,255,255,0.6); margin-top:4px;\">3D Printer Market by 2030</div>\n    </div>\n    <div style=\"background:rgba(46,139,87,0.1); border:1px solid rgba(46,139,87,0.2); border-radius:16px; padding:24px; text-align:center;\">\n      <div style=\"font-size:36px;\">&#128663;</div>\n      <div style=\"font-size:20px; font-weight:700; color:#2E8B57; margin-top:4px;\">Automotive</div>\n      <div style=\"font-size:13px; color:rgba(255,255,255,0.5); margin-top:4px;\">Rapid prototyping slashing development cycles</div>\n    </div>\n  </div>\n\n  <!-- Source -->\n  <div style=\"position:absolute; bottom:70px; left:40px; right:40px; text-align:center;\">\n  