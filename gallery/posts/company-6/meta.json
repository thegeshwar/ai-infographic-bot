cing:-12px;\">$5.2B</div>\n    <div style=\"font-size:20px; font-weight:300; color:rgba(255,255,255,0.5); margin-top:16px; letter-spacing:3px; text-transform:uppercase;\">Projected Market Size by 2034</div>\n  </div>\n\n  <!-- From indicator -->\n  <div style=\"position:absolute; top:520px; left:50%; transform:translateX(-50%); text-align:center;\">\n    <svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" style=\"margin-bottom:8px;\"><path d=\"M12 4l-6 6h4v8h4v-8h4z\" fill=\"rgba(255,255,255,0.2)\" transform=\"rotate(180 12 12)\"/></svg>\n    <div style=\"font-size:16px; font-weight:300; color:rgba(255,255,255,0.3); letter-spacing:3px; text-transform:uppercase;\">Up From</div>\n    <div style=\"font-size:64px; font-weight:900; color:#fff; margin-top:4px; letter-spacing:-3px;\">$860M</div>\n    <div style=\"font-size:16px; font-weight:300; color:rgba(255,255,255,0.4); margin-top:4px;\">in 2023</div>\n  </div>\n\n  <!-- Supporting stats row -->\n  <div style=\"position:absolute; top:760px; left:48px; right:48px; display:flex; gap:20px;\">\n\n    <!-- CAGR -->\n    <div style=\"flex:1; border:1px solid rgba(255,102,0,0.2); padding:28px 20px; text-align:center;\">\n      <div style=\"font-size:56px; font-weight:900; color:#ff6600; letter-spacing:-2px;\">20%+</div>\n      <div style=\"font-size:16px; font-weight:300; color:rgba(255,255,255,0.4); margin-top:8px; letter-spacing:2px; text-transform:uppercase;\">CAGR Growth</div>\n    </div>\n\n    <!-- Healthcare -->\n    <div style=\"flex:1; border:1px solid rgba(255,255,255,0.08); padding:28px 20px; text-align:center;\">\n      <svg width=\"40\" height=\"40\" viewBox=\"0 0 40 40\" style=\"margin-bottom:8px;\"><rect x=\"16\" y=\"8\" width=\"8\" height=\"24\" rx=\"1\" fill=\"rgba(255,102,0,0.6)\"/><rect x=\"8\" y=\"16\" width=\"24\" height=\"8\" rx=\"1\" fill=\"rgba(255,102,0,0.6)\"/></svg>\n      <div style=\"font-size:20px; font-weight:700; color:#fff;\">Healthcare</div>\n      <div style=\"font-size:14px; font-weight:300; color:rgba(255,255,255,0.4); margin-top:4px;\">Implants, surgical guides</div>\n    </div>\n\n    <!-- Aerospace -->\n    <div style=\"flex:1; border:1px solid rgba(255,255,255,0.08); padding:28px 20px; text-align:center;\">\n      <svg width=\"40\" height=\"40\" viewBox=\"0 0 40 40\" style=\"margin-bottom:8px;\"><path d=\"M20 6l4 12h10l-8 6 3 12-9-7-9 7 3-12-8-6h10z\" fill=\"none\" stroke=\"rgba(255,102,0,0.6)\" stroke-width=\"1.5\"/></svg>\n      <div style=\"font-size:20px; font-weight:700; color:#fff;\">Aerospace</div>\n      <div style=\"font-size:14px; font-weight:300; color:rgba(255,255,255,0.4); margin-top:4px;\">Lightweight components</div>\n    </div>\n\n  </div>\n\n  <!-- Bottom sector cards -->\n  <div style=\"position:absolute; top:960px; left:48px; right:48px; display:flex; gap:20px;\">\n    <div style=\"flex:1; border:1px solid rgba(255,255,255,0.08); padding:28px 20px; text-align:center;\">\n      <svg width=\"40\" height=\"40\" viewBox=\"0 0 40 40\" style=\"margin-bottom:8px;\"><rect x=\"8\" y=\"20\" width=\"6\" height=\"12\" rx=\"1\" fill=\"rgba(255,102,0,0.5)\"/><rect x=\"17\" y=\"14\" width=\"6\" height=\"18\" rx=\"1\" fill=\"rgba(255,102,0,0.6)\"/><rect x=\"26\" y=\"8\" width=\"6\" height=\"24\" rx=\"1\" fill=\"rgba(255,102,0,0.7)\"/></svg>\n      <div style=\"font-size:20px; font-weight:700; color:#fff;\">Automotive</div>\n      <div style=\"font-size:14px; font-weight:300; color:rgba(255,255,255,0.4); margin-top:4px;\">Rapid prototyping</div>\n    </div>\n    <div style=\"flex:1; border:1px solid rgba(255,102,0,0.2); padding:28px 20px; text-align:center;\">\n      <div style=\"font-size:56px; font-weight:900; color:#ff6600; letter-spacing:-2px;\">6x</div>\n      <div style=\"font-size:16px; font-weight:300; color:rgba(255,255,255,0.4); margin-top:8px; letter-spacing:2px; text-transform:uppercase;\">Growth in 10 Years</div>\n    </div>\n    <div style=\"flex:1; border:1px solid rgba(255,255,255,0.08); padding:28px 20px; text-align:center;\">\n      <svg width=\"40\" height=\"40\" viewBox=\"0 0 40 40\" style=\"margin-bottom:8px;\"><circle cx=\"20\" cy=\"20\" r=\"12\" fill=\"none\" stroke=\"rgba(255,102,0,0.5)\" stroke-width=\"1.5\"/><path d=\"M20 8v12l8 5\" fill=\"none\" stroke=\"rgba(255,102,0,0.6)\" stroke-width=\"1.5\" stroke-linecap=\"round\"/></svg>\n      <div style=\"font-size:20px; font-weight:700; color:#fff;\">Electronics</div>\n      <div style=\"font-size:14px; font-weight:300; color:rgba(255,255,255,0.4); margin-top:4px;\">Functional testing</div>\n    </div>\n  </div>\n\n  <!-- Bottom insight -->\n  <div style=\"position:absolute; bottom:80px; left:48px; right:48px; border-top:1px solid rgba(255,255,255,0.06); padding-top:16px;\">\n    <div style=\"font-size:18px; font-weight:300; color:rgba(255,255,255,0.5); line-height:1.5;\">India is the fastest growing additive manufacturing market in Asia. PCB fabrication and 3D printing are converging.</div>\n  </div>\n\n  <!-- Footer -->\n  <div style=\"position:absolute; bottom:28px; left:48px; right:48px; display:flex; justify-content:space-between; align-items:center;\">\n    <div style=\"font-size:12px; color:rgba(255,255,255,0.25);\">cucircuits.com</div>\n    <div style=\"font-size:12px; color:rgba(255,255,255,0.2);\">Source: IMARC Group, Grand View Research, MarkNtel Advisors</div>\n  </div>\n\n</div>"
