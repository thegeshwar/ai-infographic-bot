shrink:0;\">📈</div>\n        <div><div style=\"font-size:20px;color:rgba(255,255,255,0.65);font-weight:600;\">Hiring is the primary scaling strategy</div><div style=\"font-size:14px;color:rgba(255,255,255,0.3);margin-top:2px;\">More revenue = more headcount</div></div>\n      </div>\n      <div style=\"display:flex;align-items:center;gap:16px;\">\n        <div style=\"width:64px;height:64px;background:rgba(255,255,255,0.06);border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:28px;flex-shrink:0;\">💰</div>\n        <div><div style=\"font-size:20px;color:rgba(255,255,255,0.65);font-weight:600;\">Service costs tied to labor costs</div><div style=\"font-size:14px;color:rgba(255,255,255,0.3);margin-top:2px;\">Inflation follows wages upward</div></div>\n      </div>\n    </div>\n  </div>\n\n  <!-- Divider with arrow -->\n  <div style=\"position:relative;z-index:3;display:flex;align-items:center;justify-content:center;height:60px;\">\n    <div style=\"position:absolute;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,#f59e0b,transparent);\"></div>\n    <div style=\"background:#f59e0b;color:#000;font-size:14px;font-weight:800;padding:10px 28px;border-radius:30px;letter-spacing:3px;z-index:4;\">⚡ H1 2026 ⚡</div>\n  </div>\n\n  <!-- AFTER zone (bottom half) -->\n  <div style=\"flex:1;background:linear-gradient(180deg,#0d2818 0%,#1a3a2a 100%);display:flex;flex-direction:column;padding:30px 60px 40px;position:relative;\">\n    <div style=\"position:absolute;top:0;left:0;width:100%;height:100%;background:repeating-linear-gradient(0deg,transparent,transparent 30px,rgba(52,211,153,0.03) 30px,rgba(52,211,153,0.03) 31px);\"></div>\n\n    <div style=\"z-index:2;font-size:16px;color:rgba(52,211,153,0.6);letter-spacing:5px;font-weight:700;margin-bottom:10px;\">AFTER TRANSFORMATIVE AI</div>\n    <div style=\"z-index:2;font-size:36px;font-weight:800;color:#6ee7b7;margin-bottom:24px;line-height:1.2;\">The New Reality</div>\n\n    <div s