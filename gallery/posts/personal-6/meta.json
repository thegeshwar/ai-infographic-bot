div style=\"width:64px;height:64px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;\"><svg width=\"30\" height=\"30\" viewBox=\"0 0 30 30\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M5 24L15 6l10 18\" stroke=\"rgba(255,255,255,0.5)\" stroke-width=\"2\" fill=\"none\"/><line x1=\"9\" y1=\"18\" x2=\"21\" y2=\"18\" stroke=\"rgba(255,255,255,0.3)\" stroke-width=\"2\"/></svg></div><div><div style=\"font-size:22px;color:rgba(255,255,255,0.7);font-weight:700;\">Hiring is the primary scaling strategy</div><div style=\"font-size:16px;color:rgba(255,255,255,0.35);margin-top:6px;font-weight:300;\">More revenue means more headcount always</div></div></div><div style=\"display:flex;align-items:flex-start;gap:20px;\"><div style=\"width:64px;height:64px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;\"><svg width=\"30\" height=\"30\" viewBox=\"0 0 30 30\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><circle cx=\"15\" cy=\"15\" r=\"10\" stroke=\"rgba(255,255,255,0.5)\" stroke-width=\"2\"/><path d=\"M15 9v6l4 4\" stroke=\"rgba(255,255,255,0.5)\" stroke-width=\"2\"/></svg></div><div><div style=\"font-size:22px;color:rgba(255,255,255,0.7);font-weight:700;\">Service costs tied to labor costs</div><div style=\"font-size:16px;color:rgba(255,255,255,0.35);margin-top:6px;font-weight:300;\">Inflation follows wages upward every cycle</div></div></div></div></div><div style=\"position:relative;z-index:3;display:flex;align-items:center;justify-content:center;height:80px;background:linear-gradient(180deg,#1a1424,#0d1a14);\"><div style=\"position:absolute;left:0;right:0;height:3px;background:linear-gradient(90deg,transparent,#f59e0b,transparent);\"></div><div style=\"background:#f59e0b;color:#000;font-size:20px;font-weight:900;padding:14px 48px;letter-spacing:5px;z-index:4;\">H1 2026</d